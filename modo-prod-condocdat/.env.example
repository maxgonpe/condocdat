# Producción Condocdat — PostgreSQL (misma instancia que Talleres)
# Copia a .env en el servidor y rellena los valores.
# Uso: desde el directorio del proyecto (condocdat):
#   docker compose -f modo-prod-condocdat/docker-compose.prod.yml up -d

SECRET_KEY=genera-una-clave-secreta-segura
ALLOWED_HOSTS=condocdat.netgogo.cl

# PostgreSQL — mismo servidor que Talleres (contenedor postgres_talleres)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=condocdat_db
DB_USER=maxgonpe
DB_PASSWORD=tu_password_postgres
DB_HOST=postgres_talleres
DB_PORT=5432

# En el servidor el contenedor condocdat debe estar en la misma red que postgres_talleres.
# Red usada: myproject_netgogo_default (donde corre postgres_talleres).
