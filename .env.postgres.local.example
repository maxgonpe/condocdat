# Copia a .env.postgres.local y úsalo cuando quieras conectar a PostgreSQL local.
# Uso: source .env.postgres.local  (bash: export $(grep -v '^#' .env.postgres.local | xargs))
# No subas .env.postgres.local a git si tiene contraseñas reales.

DB_ENGINE=django.db.backends.postgresql
DB_NAME=condocdat_db
DB_USER=condocdat_user
DB_PASSWORD=condocdat_local
DB_HOST=127.0.0.1
DB_PORT=5432

# Correo (Outlook / Office 365) para Enviar correo desde CONDOCDAT
# Si tu cuenta tiene 2FA, crea una "Contraseña de aplicación" en https://account.microsoft.com/security
EMAIL_HOST=smtp.office365.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=max.gonzalez@propamat.cl
EMAIL_HOST_PASSWORD=tu_contraseña_o_contraseña_de_aplicacion
DEFAULT_FROM_EMAIL=max.gonzalez@propamat.cl
