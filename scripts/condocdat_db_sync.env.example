# Copia a condocdat_db_sync.env (mismo directorio) y rellena valores reales.
#   cp scripts/condocdat_db_sync.env.example scripts/condocdat_db_sync.env
# El archivo condocdat_db_sync.env está en .gitignore.
#
# Uso:
#   ./scripts/condocdat_db_sync.sh dump
#   ./scripts/condocdat_db_sync.sh restore scripts/condocdat_prod_20260112_120000.pgdump

# --- Volcado desde producción (elige un método) ---

# Por defecto (servidor donde está Docker): volcado con docker exec, sin SSH.
SYNC_METHOD=docker_local
PROD_PG_CONTAINER=postgres_talleres
PROD_PG_USER=maxgonpe
PROD_DB_NAME=condocdat_db

# Solo desde tu PC (sin entrar al servidor): descomenta y pon tu usuario@host real.
# SYNC_METHOD=docker_ssh
# PROD_SSH_HOST=usuario@tu-servidor-real.cl

# Si pg_dump pide contraseña dentro del contenedor, descomenta y rellena:
# PROD_DOCKER_EXEC_EXTRA=-e PGPASSWORD=tu_password

# Alternativa: conexión directa (VPN, túnel SSH manual, etc.). Pon SYNC_METHOD=direct
# y define PGHOST / PGPORT / PGUSER / PGPASSWORD / PGDATABASE o usa las variables PROD_* de abajo.
# SYNC_METHOD=direct
# PROD_PG_HOST=127.0.0.1
# PROD_PG_PORT=15432
# PROD_PG_USER=maxgonpe
# PROD_PG_PASSWORD=
# PROD_DB_NAME=condocdat_db

# Comando remoto completo (opcional). Si está definido, se ignora la plantilla docker_ssh
# y se ejecuta: ssh PROD_SSH_HOST "$PROD_SSH_DUMP_COMMAND" > archivo
# PROD_SSH_DUMP_COMMAND=docker exec -i postgres_talleres pg_dump -U maxgonpe -d condocdat_db -F c

# --- Restauración en tu PostgreSQL local ---

LOCAL_PG_HOST=127.0.0.1
LOCAL_PG_PORT=5432
# Postgres nativo (como defaults de settings.py): maxgonpe + tu clave local.
# Postgres en Docker (docker-compose.postgres.yml): condocdat_user / condocdat_local y LOCAL_USE_DOCKER=true.
LOCAL_PG_USER=condocdat_user
LOCAL_PG_PASSWORD=condocdat_local
LOCAL_DB_NAME=condocdat_db

LOCAL_USE_DOCKER=false
LOCAL_PG_CONTAINER=condocdat_postgres_local

# clean (recomendado sin superusuario): solo pg_restore --clean sobre la base existente.
# recreate: DROP DATABASE + CREATE (requiere CREATEDB o rol postgres).
LOCAL_RESTORE_MODE=clean
